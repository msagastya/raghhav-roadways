# Server Configuration
NODE_ENV=development
PORT=2026
API_VERSION=v1

# Database Configuration - DO NOT commit real credentials
DATABASE_URL="postgresql://user:password@localhost:5432/raghhav_roadways"

# JWT Configuration - Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-min-32-character-secret-key-change-in-production"
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET="your-min-32-character-refresh-secret-key-change-in-production"
JWT_REFRESH_EXPIRES_IN=30d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# File Storage
STORAGE_PATH=./storage
MAX_FILE_SIZE=10485760

# Company Details
COMPANY_NAME="Raghhav Roadways"
COMPANY_GSTIN="XXAABBCC1234D1Z0"
COMPANY_ADDRESS="Your Company Address"
COMPANY_PHONE="9876543210"
COMPANY_EMAIL="info@raghhavroadways.com"
COMPANY_BANK_NAME="Bank Name"
COMPANY_BANK_ACCOUNT="Account Number"
COMPANY_BANK_IFSC="BANK0001234"
COMPANY_BANK_BRANCH="Branch Name"

# Logging
LOG_LEVEL=info
