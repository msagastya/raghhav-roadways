# Production Environment Variables for Frontend
# These are used when building for production

# API Configuration - Update with your actual Vercel backend URL after deployment
# Format: https://your-backend-project.vercel.app/api/v1
NEXT_PUBLIC_API_URL=https://your-backend-project.vercel.app/api/v1

# Environment
NODE_ENV=production

# App Settings
NEXT_PUBLIC_APP_NAME=Raghhav Roadways
NEXT_PUBLIC_APP_VERSION=1.0.0

# Feature Flags
NEXT_PUBLIC_ENABLE_DEMO_MODE=false
